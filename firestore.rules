rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: teams
    // Fields:
    //   - name: string (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: teams/{teamId}/players
    // Fields:
    //   - name: string (required)
    //   - teamId: string (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: teams/{teamId}/matches
    // Fields:
    //   - teamId: string (required)
    //   - matchday: int (required)
    //   - opponent: string (required)
    //   - result: string (required)
    //   - date: timestamp (optional)
    //
    // Collection: teams/{teamId}/matches/{matchId}/stats
    // Fields:
    //   - playerId: string (required)
    //   - matchId: string (required)
    //   - minutes: int (required)
    //   - goals: int (required)
    //   - yellowCards: int (required)
    //   - redCards: int (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alvaro.aloper@gmail.com" && request.auth.token.email_verified == true));
    }

    function isPublicAdmin(userId) {
      let user = get(/databases/$(database)/documents/users/$(userId)).data;
      return user.role == 'admin' || user.email == 'alvaro.aloper@gmail.com';
    }

    function isDocOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMember(teamId) {
      return isAuthenticated() && (isAdmin() || exists(/databases/$(database)/documents/team_members/$(request.auth.uid + "_" + teamId)));
    }

    function getRole(teamId) {
      return get(/databases/$(database)/documents/team_members/$(request.auth.uid + "_" + teamId)).data.role;
    }

    function isOwner(teamId) {
      return isAuthenticated() && (isAdmin() || getRole(teamId) == 'owner');
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['google_id', 'name', 'email']) &&
             data.google_id is string &&
             (data.name == null || data.name is string) &&
             (data.email == null || data.email is string) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'owner_id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.owner_id == request.auth.uid;
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['team_id', 'user_id', 'role']) &&
             data.team_id is string &&
             data.user_id is string &&
             data.role in ['owner', 'coach'];
    }

    function isValidInviteCode(data) {
      return data.keys().hasAll(['team_id', 'code', 'created_by', 'used']) &&
             data.team_id is string &&
             data.code is string &&
             data.created_by == request.auth.uid &&
             data.used == false;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'teamId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teamId is string;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['teamId', 'matchday', 'opponent', 'result']) &&
             data.teamId is string &&
             data.matchday is int &&
             data.opponent is string && data.opponent.size() > 0 &&
             data.result is string &&
             (!('ownGoals' in data) || data.ownGoals is int);
    }

    function isValidStat(data) {
      return data.keys().hasAll(['playerId', 'matchId', 'minutes', 'goals', 'yellowCards', 'redCards']) &&
             data.playerId is string &&
             data.matchId is string &&
             data.minutes is int &&
             data.goals is int &&
             data.yellowCards is int &&
             data.redCards is int &&
             (!('doubleYellowCards' in data) || data.doubleYellowCards is bool);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() || resource.data.email == "alvaro.aloper@gmail.com";
      allow create: if isAuthenticated() && isDocOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isDocOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }

    match /teams/{teamId} {
      allow read: if (isAuthenticated() && isMember(teamId)) || isPublicAdmin(resource.data.owner_id);
      allow create: if isAuthenticated() && isValidTeam(request.resource.data);
      allow update, delete: if isAuthenticated() && isOwner(teamId);

      match /players/{playerId} {
        allow read: if (isAuthenticated() && isMember(teamId)) || isPublicAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data.owner_id);
        allow write: if isAuthenticated() && isMember(teamId);
      }

      match /matches/{matchId} {
        allow read: if (isAuthenticated() && isMember(teamId)) || isPublicAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data.owner_id);
        allow write: if isAuthenticated() && isMember(teamId);

        match /stats/{statId} {
          allow read: if (isAuthenticated() && isMember(teamId)) || isPublicAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data.owner_id);
          allow write: if isAuthenticated() && isMember(teamId);
        }
      }
    }

    match /team_members/{memberId} {
      // memberId format: userId_teamId
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.user_id || isOwner(resource.data.team_id))) || 
                    isPublicAdmin(get(/databases/$(database)/documents/teams/$(resource.data.team_id)).data.owner_id);
      allow create: if isAuthenticated() && (request.resource.data.role == 'owner' || exists(/databases/$(database)/documents/invite_codes/$(request.resource.data.invite_code)));
      allow delete: if isAuthenticated() && isOwner(resource.data.team_id) && resource.data.role != 'owner';
    }

    match /invite_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.team_id) && isValidInviteCode(request.resource.data);
      allow update: if isAuthenticated() && request.resource.data.used == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']);
    }
  }
}
